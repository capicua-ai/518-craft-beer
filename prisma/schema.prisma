// Prisma schema file — https://pris.ly/d/prisma-schema
//
// Getting started:
//   1. Set DATABASE_URL in .env.local (never commit it)
//   2. Define your models below
//   3. Run: pnpm prisma migrate dev --name init
//
// Notes for Prisma 7:
//   - The datasource URL lives in prisma.config.ts (not here)
//   - The PrismaClient is instantiated with an adapter in src/lib/db.ts
//   - The generated client lives in src/generated/prisma — always import via @/lib/db
//
// The singleton is in src/lib/db.ts. Always import `db` from there.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Define your models below this line.

model SiteSettings {
  id               String   @id @default(uuid())
  hero_headline    String
  hero_subheadline String
  footer_address   String
  footer_website   String
  footer_instagram String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("site_settings")
}

model Beer {
  id              String   @id @default(uuid())
  name            String
  style           String
  abv             String
  size_oz         Int      @default(12)
  description     String
  label_image_url String?
  accent_color    String   @default("#C97D1A")
  bg_color        String   @default("#1A0800")
  flavor_tags     String[] @default([])
  display_order   Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("beers")
}
